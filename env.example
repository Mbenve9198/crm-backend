# Database Configuration
MONGODB_URI=mongodb://localhost:27017/menuchatcrm

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=menuchat-crm-super-secret-key-2024
JWT_EXPIRES_IN=7d

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OpenWA License Configuration
# Ottieni le licenze da: https://gum.co/open-wa?tier=1%20Restricted%20License%20Key
# IMPORTANTE: Ogni licenza è valida per UN SOLO numero WhatsApp

# Licenza principale (compatibilità retroattiva)
OPENWA_LICENSE_KEY=your_openwa_license_key_here

# Licenze specifiche per numero (raccomandato per setup multi-numero)
OPENWA_LICENSE_KEY_PRINCIPALE=your_license_for_393342746427_here
OPENWA_LICENSE_KEY_MARKETING=your_license_for_393663153304_here

# OpenWA Configuration (Required for Railway/Render deployment)
OPENWA_HEADLESS=true
OPENWA_SESSION_DATA_PATH=./wa-sessions

# Storage Configuration for Production (Railway uses tmpdir automatically)
# OPENWA_STORAGE_PATH=/tmp/wa-storage  # For Railway/Cloud deployment

# Browser Configuration for Production (bypasses Chrome installation requirement)
OPENWA_BROWSER_REVISION=737027

# Chrome Configuration (Only if you have Chrome installed - NOT needed for Railway/Render)
# CHROME_PATH=/usr/bin/google-chrome
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome 