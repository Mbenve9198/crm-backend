{
  "name": "menuchat-crm-backend",
  "version": "1.0.0",
  "description": "Backend minimale per MenuChatCRM - Gestione contatti con import CSV e proprietà dinamiche",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "create-admin": "node scripts/createAdmin.js",
    "create-users": "node scripts/createUsers.js",
    "create-production-users": "node scripts/createProductionUsers.js",
    "fix-email-index": "node scripts/fixEmailIndex.js",
    "inspect-db": "node scripts/inspectDatabase.js",
    "trigger-outreach-test": "node scripts/triggerOutreachTest.js",
    "clean-calls": "node scripts/cleanStuckCalls.js",
    "clean-all-calls": "node scripts/cleanAllActiveCalls.js",
    "test-redis": "node scripts/testRedis.js",
    "test-uploads": "node scripts/testUploadsPermissions.js",
    "test-csv-mapping": "node scripts/testCsvMappingFeature.js",
    "test-advanced-filters": "node scripts/testAdvancedFilters.js",
    "test-bulk-deletion": "node scripts/testBulkDeletion.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:redteam": "vitest run tests/redteam/",
    "test:eval": "vitest run tests/eval/",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "crm",
    "contacts",
    "csv-import",
    "mongodb",
    "express"
  ],
  "author": "MenuChat Team",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "imagekit": "^5.2.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.9.3",
    "stripe": "^22.0.0",
    "twilio": "^5.4.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2",
    "vitest": "^4.1.2"
  }
}
